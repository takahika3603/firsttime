<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Blog CMS Builder PRO</title>

<style>
:root{
  --bg:#0b0f1a;
  --card:rgba(255,255,255,0.06);
  --border:rgba(255,255,255,0.12);
  --text:#fff;
  --muted:rgba(255,255,255,0.6);
  --accent:linear-gradient(135deg,#a5b4fc,#f9a8d4);
}
input{
width:100%;
padding:10px;
border-radius:10px;
border:none;
margin:6px 0;
font-family:monospace;
}
body{
margin:0;
font-family:-apple-system,BlinkMacSystemFont,"Hiragino Sans","Meiryo",sans-serif;
background:var(--bg);
color:var(--text);
padding:16px;
}

.container{
max-width:760px;
margin:0 auto;
display:flex;
flex-direction:column;
gap:12px;
}

/* カード */
.card{
background:var(--card);
border:1px solid var(--border);
border-radius:14px;
padding:12px;
}

/* ボタン */
button{
width:100%;
padding:12px;
border:none;
border-radius:12px;
background:var(--accent);
color:#fff;
font-weight:bold;
cursor:pointer;
}

/* =========================
ブロックUI（改善版）
========================= */
.block{
display:flex;
align-items:center;
justify-content:space-between;
gap:10px;
padding:10px;
margin:6px 0;
border-radius:10px;
background:rgba(255,255,255,0.05);
cursor:grab;
}

/* 左：ドラッグ */
.drag{
width:22px;
text-align:center;
opacity:0.7;
font-size:18px;
cursor:grab;
}

/* 中：チェック＋タイトル */
.block-main{
display:flex;
align-items:center;
gap:10px;
flex:1;
min-width:0;
}

/* タイトル */
.block-title{
font-size:14px;
white-space:nowrap;
overflow:hidden;
text-overflow:ellipsis;
}

/* 右：情報 */
.block-right{
display:flex;
align-items:center;
gap:8px;
font-size:11px;
opacity:0.7;
flex-shrink:0;
}

/* 編集ボタン小さく */
.edit{
color:#a5b4fc;
cursor:pointer;
font-size:11px;
}

/* モーダル */
.modal{
position:fixed;
inset:0;
background:rgba(0,0,0,0.75);
display:none;
align-items:center;
justify-content:center;
padding:14px;
z-index:999;
}

.modal-box{
width:100%;
max-width:520px;
}

.preview{
background:#fff;
color:#333;
padding:14px;
border-radius:12px;
max-height:70vh;
overflow:auto;
line-height:1.6;
}

/* input */
textarea{
width:100%;
height:120px;
padding:10px;
border-radius:10px;
border:none;
margin-top:10px;
font-family:monospace;
}

.small{
font-size:12px;
color:var(--muted);
}
</style>
</head>

<body>

<div class="container">

<h2>Blog CMS Builder PRO</h2>

<!-- ボタン -->
<div class="card">
<button onclick="openPreview()">👀 プレビュー</button>
</div>
  
<!-- ブロック -->
<div class="card" id="list"></div>

<!-- 自由入力 -->
<div class="card">
<div class="small">自由入力</div>
<textarea id="input"></textarea>
</div>

</div>

<!-- プレビュー -->
<div class="modal" id="modal">
<div class="modal-box">
<button onclick="closePreview()">✖ 閉じる</button>
<div id="preview" class="preview"></div>
</div>
</div>

<!-- =========================
編集モーダル（ここを追加）
========================= -->
<div class="modal" id="editModal">
<div class="modal-box">

<button onclick="closeEdit()">✖ 閉じる</button>

<div class="small">タイトル</div>
<input id="editTitle">

<div class="small">内容</div>
<textarea id="editText"></textarea>

<button onclick="saveEdit()">💾 保存</button>

</div>
</div>
  
<script>

/* =========================
データ
========================= */
let blocks = [
{ id:"salary", title:"給与ボックス", text:"給与は安定しています", priority:1, checked:false },
{ id:"job", title:"仕事内容ボックス", text:"未経験でもOKです", priority:1, checked:false },
{ id:"easy", title:"未経験OKボックス", text:"すぐに活躍できます", priority:1, checked:false },
{ id:"env", title:"環境ボックス", text:"働きやすい環境です", priority:1, checked:false }
];

let dragIndex = null;

/* =========================
保存
========================= */
function save(){
localStorage.setItem("cms", JSON.stringify(blocks));
alert("保存しました");
}

/* =========================
復元
========================= */
function load(){
const data = localStorage.getItem("cms");
if(data) blocks = JSON.parse(data);
}

/* =========================
描画
========================= */
function render(){

let html="";

blocks.forEach((b,i)=>{
html+=`
<div class="block"
draggable="true"
ondragstart="dragStart(${i})"
ondrop="drop(${i})"
ondragover="event.preventDefault()">

<!-- 左：ドラッグ -->
<div class="drag">≡</div>

<!-- 中：チェック＋タイトル -->
<div class="block-main">
<input type="checkbox" onchange="toggle(${i})" ${b.checked?"checked":""}>
<span class="block-title">${b.title}</span>
</div>

<!-- 右：優先＋編集 -->
<div class="block-right">
<span>優先:${b.priority}</span>
<span class="edit" onclick="edit(${i})">編集</span>
</div>

</div>
`;
});

document.getElementById("list").innerHTML = html;
}

/* =========================
チェック
========================= */
function toggle(i){
blocks[i].checked = !blocks[i].checked;
}

/* =========================
ドラッグ
========================= */
function dragStart(i){
dragIndex = i;
}

function drop(i){
const temp = blocks[dragIndex];
blocks.splice(dragIndex,1);
blocks.splice(i,0,temp);
render();
}

/* =========================
プレビューHTML生成
========================= */
function generateHTML(){

let html = `<h1>ブログプレビュー</h1>`;

blocks
.filter(b=>b.checked)
.forEach(b=>{
html+=`
<div style="margin:10px 0;padding:10px;border:1px solid #ddd;border-radius:8px;">
<h3>${b.title}</h3>
<p>${b.text}</p>
</div>
`;
});

html+=`<p>${document.getElementById("input").value}</p>`;

return html;
}

/* =========================
プレビュー表示
========================= */
function openPreview(){
document.getElementById("preview").innerHTML = generateHTML();
document.getElementById("modal").style.display="flex";
}

function closePreview(){
document.getElementById("modal").style.display="none";
}

/* =========================
編集（仮）
========================= */
let editIndex = null;

/* =========================
編集モーダルを開く
========================= */
function edit(i){
editIndex = i;

// 今のデータをフォームに入れる
document.getElementById("editTitle").value = blocks[i].title;
document.getElementById("editText").value = blocks[i].text;

// モーダル表示
document.getElementById("editModal").style.display = "flex";
}

/* =========================
閉じる
========================= */
function closeEdit(){
document.getElementById("editModal").style.display = "none";
}

/* =========================
保存
========================= */
function saveEdit(){

// 値を反映
blocks[editIndex].title =
document.getElementById("editTitle").value;

blocks[editIndex].text =
document.getElementById("editText").value;

// 閉じる
closeEdit();

// 再描画
render();
}

/* =========================
初期化
========================= */
load();
render();

</script>

</body>
</html>
